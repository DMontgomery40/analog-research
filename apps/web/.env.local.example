# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Set at least one server-side privileged key:
# - SUPABASE_SERVICE_ROLE_KEY (legacy)
# - SUPABASE_SECRET_KEY (new dashboard label)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=sb_secret_xxx

# Stripe (Required for payments)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Connect webhooks (connected accounts)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Optional: isolated Stripe Connect sample sandbox (admin + storefront demo)
STRIPE_CONNECT_SAMPLE_ENABLED=false
STRIPE_CONNECT_SAMPLE_WEBHOOK_SECRET=whsec_xxx
# Optional callback origin override for the sample onboarding links.
# If unset, routes derive origin from NEXT_PUBLIC_SITE_URL / request host.
STRIPE_CONNECT_SAMPLE_APP_URL=
# Optional: Stripe processing fee estimates used to gross-up payer-paid processing fees
STRIPE_PROCESSING_FEE_BPS_ESTIMATE=440
STRIPE_PROCESSING_FIXED_FEE_MINOR=30
STRIPE_PROCESSING_FX_FEE_BPS_ESTIMATE=100

# Coinbase Commerce / Payment Acceptance (Required for crypto escrow)
# Auth (preferred): CDP JWT auth via API key id + secret
# COINBASE_COMMERCE_API_KEY_ID=organizations/{orgId}/apiKeys/{keyId}
# COINBASE_COMMERCE_API_KEY_SECRET=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
#
# Auth (legacy): static bearer token (if you have one)
COINBASE_COMMERCE_API_TOKEN=cbtoken_xxx
COINBASE_COMMERCE_WEBHOOK_SHARED_SECRET=whsec_xxx
COINBASE_COMMERCE_FEE_RECEIVER=0xYourPlatformWalletAddress
COINBASE_COMMERCE_CHAIN=base
# Optional: override inferred chain/network id (defaults to Base=8453)
COINBASE_COMMERCE_NETWORK_ID=8453
# Optional: platform fee in basis points (default 300 = 3%)
COINBASE_COMMERCE_PLATFORM_FEE_BPS=300
# Optional: comma-separated booking settlement currencies supported by your Coinbase setup
# Example: USD,EUR,USDC
COINBASE_COMMERCE_SUPPORTED_SETTLEMENT_CURRENCIES=USD,USDC
# Legacy single-currency fallback (kept for backward compatibility)
COINBASE_COMMERCE_CURRENCY=usdc

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public showcase fail-closed controls
# curated (default in code): only IDs in *_IDS are publicly visible; if IDs are not exactly 3, feeds fail closed.
# open: disable curated filtering and expose normal public browse/detail behavior.
PUBLIC_SHOWCASE_MODE=curated
PUBLIC_SHOWCASE_HUMAN_IDS=
PUBLIC_SHOWCASE_BOUNTY_IDS=

# MCP OAuth (ChatGPT App)
MCP_OAUTH_ENABLED=false
MCP_OAUTH_PROVIDER=auth0
MCP_OAUTH_ISSUER=
MCP_OAUTH_AUDIENCE=
# OAuth resource identifier should match the API identifier (audience) in Auth0.
# Local example:
MCP_OAUTH_RESOURCE=http://localhost:3000
MCP_OAUTH_SCOPES_READ=analogresearch.read
MCP_OAUTH_SCOPES_WRITE=analogresearch.write
AUTH0_MCP_LINK_CLIENT_ID=
AUTH0_MCP_LINK_CLIENT_SECRET=
# Optional: widget domain for ChatGPT App UI templates.
# Must be a unique domain per app for submission (falls back to NEXT_PUBLIC_SITE_URL).
MCP_WIDGET_DOMAIN=
# Optional local fallback for ChatGPT MCP testing (ignored in production).
# If a ChatGPT MCP request has no auth header, this key is used to authenticate as a Molty.
MCP_CHATGPT_ADMIN_API_KEY=

# Required for auto-complete endpoint auth
CRON_SECRET=your-cron-secret

# Moderation (OpenRouter)
MODERATION_PROVIDER=openrouter
OPENROUTER_API_KEY=
MODERATION_MODEL_PRIMARY=mistralai/mistral-nemo
MODERATION_MODEL_ESCALATION=meta-llama/llama-guard-3-8b
MODERATION_TIMEOUT_MS=1800
MODERATION_FAIL_CONFIDENCE=0.93
MODERATION_WARN_CONFIDENCE=0.60
MODERATION_MAX_INPUT_CHARS=12000
MODERATION_DAILY_TOKEN_BUDGET=1000000

# Optional admin allowlist for moderation config endpoints
MODERATION_ADMIN_EMAILS=

# Optional admin allowlist for the /admin dashboard (comma-separated emails)
ADMIN_EMAILS=

# Optional: Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# External Integrations (ProxyPics / External fulfillment)
# 32-byte random key, base64-encoded (required to encrypt provider credentials at rest)
INTEGRATIONS_ENCRYPTION_KEY_BASE64=
# Webhook tokens (shared secret) for ProxyPics webhook endpoints
PROXYPICS_WEBHOOK_TOKEN_LIVE=
PROXYPICS_WEBHOOK_TOKEN_SANDBOX=
